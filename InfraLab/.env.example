# InfraLab 本番環境変数テンプレート
# このファイルは Git に追跡される（実値なし）
# 実際の .env は VPS 上に配置し、Git には含めない（.gitignore 対象）

# PostgreSQL 接続文字列
# shared-postgres コンテナへの接続（shared-pg-net ネットワーク経由）
# infralab DB ユーザー・パスワードは VPS 上で設定する（docs/DEPLOYMENT.md 参照）
INFRALAB_DB_CONNECTION=Host=shared-postgres;Port=5432;Database=infralab;Username=infralab_user;Password=<パスワードをここに設定>
INFRALAB_TRUSTED_PROXY_NETWORKS=REPLACE_WITH_TRAEFIK_NETWORK_CIDR
INFRALAB_IMAGE_REPOSITORY=REPLACE_WITH_IMAGE_REPOSITORY
INFRALAB_IMAGE_TAG=git-REPLACE_WITH_COMMIT_SHA
