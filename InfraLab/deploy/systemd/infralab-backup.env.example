BACKUP_DIR=/var/backups/infralab
BACKUP_RETENTION_DAYS=14
BACKUP_SUCCESS_MARKER=/var/lib/infralab-backup/last-success
BACKUP_LOCK_FILE=/var/lib/infralab-backup/backup.lock
INFRALAB_APP_DB=REPLACE_WITH_INFRALAB_DATABASE_NAME
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=REPLACE_WITH_INFRALAB_DATABASE_NAME
PGUSER=REPLACE_WITH_DEDICATED_BACKUP_ROLE
PGPASSFILE=/etc/infralab/backup.pgpass
