{
  "id":"linux-systemd-203-001", "title":"デプロイ後にアプリケーションサービスが起動しない", "category":"lpic1", "difficulty":"beginner", "summary":"systemd 203/EXEC の障害を調査します。", "symptoms":["WebサイトがHTTP 502を返している","Nginx自体はactive","直前にアプリケーションをデプロイした"],
  "version":{"id":"linux-systemd-203-001-v1","number":1,
  "actions":[
    {"id":"nginx-status","label":"systemctl status nginx","phase":1,"patterns":[{"value":"systemctl status nginx","validationInput":"systemctl status nginx"}],"output":"nginx.service - active (running)","revealsEvidenceIds":["nginx-active"],"cost":1,"isDangerous":false,"repeatable":true},
    {"id":"app-status","label":"systemctl status app.service","phase":1,"patterns":[{"value":"systemctl status app.service","validationInput":"systemctl status app.service"}],"output":"app.service: failed (Result: exit-code), status=203/EXEC","revealsEvidenceIds":["app-failed","exec-203"],"cost":1,"isDangerous":false,"repeatable":true},
    {"id":"app-journal","label":"journalctl -u app.service","phase":1,"patterns":[{"value":"journalctl -u app.service","validationInput":"journalctl -u app.service"}],"output":"app.service: Failed at step EXEC spawning /opt/app/start.sh: Permission denied","revealsEvidenceIds":["permission-denied"],"cost":1,"isDangerous":false,"repeatable":true},
    {"id":"unit-cat","label":"systemctl cat app.service","phase":1,"patterns":[{"value":"systemctl cat app.service","validationInput":"systemctl cat app.service"}],"output":"ExecStart=/opt/app/start.sh","revealsEvidenceIds":["exec-start"],"cost":1,"isDangerous":false,"repeatable":true},
    {"id":"ls-permissions","label":"ls -l /opt/app/start.sh","phase":1,"patterns":[{"value":"ls -l /opt/app/start.sh","validationInput":"ls -l /opt/app/start.sh"}],"output":"-rw-r--r-- 1 app app 123 Jul 12 /opt/app/start.sh","revealsEvidenceIds":["no-execute-bit"],"cost":1,"isDangerous":false,"repeatable":true},
    {"id":"disk","label":"df -h","phase":1,"patterns":[{"value":"df -h","validationInput":"df -h"}],"output":"/dev/vda1 40G 12G 28G 30% /","revealsEvidenceIds":["disk-normal"],"cost":1,"isDangerous":false,"repeatable":true},
    {"id":"port","label":"ss -lntp","phase":1,"patterns":[{"value":"ss -lntp","validationInput":"ss -lntp"}],"output":"No listener on 127.0.0.1:8080","revealsEvidenceIds":["port-closed"],"cost":1,"isDangerous":false,"repeatable":true},
    {"id":"localhost-curl","label":"curl http://127.0.0.1:8080","phase":1,"patterns":[{"value":"curl http://127.0.0.1:8080","validationInput":"curl http://127.0.0.1:8080"}],"output":"curl: (7) Failed to connect","revealsEvidenceIds":["app-unreachable"],"cost":1,"isDangerous":false,"repeatable":true}],
  "evidence":[{"id":"nginx-active","title":"Nginx","type":1,"text":"Nginxはactive。"},{"id":"app-failed","title":"app.service","type":1,"text":"app.serviceはfailed。"},{"id":"exec-203","title":"終了状態","type":1,"text":"203/EXEC。"},{"id":"permission-denied","title":"journal","type":0,"text":"Permission denied。"},{"id":"exec-start","title":"unit","type":3,"text":"ExecStart=/opt/app/start.sh。"},{"id":"no-execute-bit","title":"権限","type":1,"text":"start.shに実行権限がない。"},{"id":"disk-normal","title":"容量","type":2,"text":"ディスク容量は正常。"},{"id":"port-closed","title":"ポート","type":1,"text":"8080は待受していない。"},{"id":"app-unreachable","title":"アプリ応答","type":1,"text":"localhostへ接続できない。"}],
  "diagnoses":[{"id":"not-executable","text":"ExecStartで指定されたスクリプトに実行権限がない"},{"id":"nginx-upstream","text":"Nginx設定のupstream名が誤っている"},{"id":"disk-full","text":"ディスク容量が枯渇している"},{"id":"firewall","text":"ファイアウォールが8080番を拒否している"}],
  "remediations":[{"id":"chmod-and-restart","text":"chmod +x /opt/app/start.sh を行い app.service を再起動する"},{"id":"chmod-777","text":"chmod -R 777 /opt/app を実行する","isDangerous":true},{"id":"disable-systemd","text":"systemd unitを無効化する","isDangerous":true}],
  "verifications":[{"id":"service-active","text":"systemctl is-active app.service"},{"id":"local-response","text":"curl http://127.0.0.1:8080"},{"id":"public-response","text":"公開URLのHTTP確認"}],
  "private":{"correctDiagnosisId":"not-executable","correctRemediationId":"chmod-and-restart","requiredVerificationIds":["service-active","local-response","public-response"],"requiredEvidenceIds":["exec-203","permission-denied","exec-start","no-execute-bit"],"exemplaryPath":["app-status","app-journal","unit-cat","ls-permissions"],"explanation":"203/EXECとPermission denied、ExecStart、権限表示を結び付けると、起動スクリプトに実行権限がないことが原因と判断できます。"}}
