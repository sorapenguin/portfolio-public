{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://golab/scenario.schema.json",
  "title": "GoLab Scenario",
  "description": "A single learning scenario for GoLab.",
  "type": "object",
  "required": [
    "schemaVersion", "id", "title", "description",
    "difficulty", "category", "nodes", "connections",
    "choices", "events", "expectedStatus",
    "failPoint", "reachedNodes", "explanation", "wrongExplanation"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "string",
      "enum": ["1"],
      "description": "Schema version. Increment when breaking changes are made."
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "description": "Unique scenario identifier. Must match the filename (without .json)."
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "difficulty": {
      "type": "string",
      "enum": ["beginner", "intermediate", "advanced"]
    },
    "category": {
      "type": "string",
      "enum": ["lab1", "lab2", "lab3"]
    },
    "learningGoals": {
      "type": "array",
      "items": { "type": "string" },
      "maxItems": 10
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "items": { "$ref": "#/definitions/node" }
    },
    "connections": {
      "type": "array",
      "maxItems": 20,
      "items": { "$ref": "#/definitions/connection" }
    },
    "choices": {
      "type": "array",
      "minItems": 2,
      "maxItems": 8,
      "items": { "$ref": "#/definitions/choice" }
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "items": { "$ref": "#/definitions/event" }
    },
    "expectedStatus": {
      "type": "integer",
      "minimum": 100,
      "maximum": 599
    },
    "failPoint": {
      "type": "string",
      "description": "Node ID where the request fails. Empty string if no failure."
    },
    "reachedNodes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Node IDs the request reached before failing."
    },
    "explanation": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000,
      "description": "Shown after correct answer."
    },
    "wrongExplanation": {
      "type": "string",
      "maxLength": 2000,
      "description": "Shown after wrong answer."
    },
    "cloudMapping": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "description": "Optional mapping from node type to cloud service examples."
    }
  },
  "definitions": {
    "node": {
      "type": "object",
      "required": ["id", "type", "label"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "type": {
          "type": "string",
          "enum": ["client", "dns", "edge", "waf", "lb", "proxy", "app", "db"]
        },
        "label": { "type": "string", "minLength": 1 },
        "settings": { "type": "object" }
      }
    },
    "connection": {
      "type": "object",
      "required": ["from", "to"],
      "additionalProperties": false,
      "properties": {
        "from": { "type": "string" },
        "to":   { "type": "string" }
      }
    },
    "choice": {
      "type": "object",
      "required": ["id", "label"],
      "additionalProperties": false,
      "properties": {
        "id":    { "type": "string" },
        "label": { "type": "string", "minLength": 1 }
      }
    },
    "event": {
      "type": "object",
      "required": ["nodeId", "delayMs", "description", "status"],
      "additionalProperties": false,
      "properties": {
        "nodeId":      { "type": "string" },
        "delayMs":     { "type": "integer", "minimum": 0 },
        "description": { "type": "string", "minLength": 1 },
        "status": {
          "type": "string",
          "enum": ["ok", "error", "timeout"]
        }
      }
    }
  }
}
