<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- ステータスカード -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/surface"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_total_attack"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/gold"
                        android:text="総攻撃力: 0" />

                    <TextView
                        android:id="@+id/tv_slot_info"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="4dp"
                        android:text="スロット: 0 / 5" />

                    <TextView
                        android:id="@+id/tv_max_star"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="2dp"
                        android:text="最高★: 0  (上限 ★99)" />

                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_trash_settings"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text=""
                    app:icon="@drawable/ic_delete"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    android:padding="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 武器グリッド（全スロット表示） -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_weapons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:layout_marginBottom="10dp" />

        <!-- 合成 + 自動合成カード -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- 合成する（メインボタン） -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_merge"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="合成する"
                    android:textSize="15sp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />

                <!-- 区切り線 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="6dp" />

                <!-- 自動合成ラベル -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="自動合成"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="4dp" />

                <!-- 自動合成（無料）ボタン -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_auto_merge_free"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="自動合成（無料）3分"
                    android:textSize="13sp"
                    android:padding="6dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                <!-- 自動合成（広告）ボタン -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_auto_merge_ad"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="自動合成（広告）3分"
                    android:textSize="13sp"
                    android:padding="6dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:visibility="gone"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                <!-- ステータス行 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="6dp">

                    <TextView
                        android:id="@+id/tv_auto_merge_status"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="10sp"
                        android:textColor="@color/text_secondary"
                        android:text="停止中" />

                    <TextView
                        android:id="@+id/tv_auto_merge_free_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="10sp"
                        android:textColor="@color/text_secondary"
                        android:text="無料残り: 3 / 3 回" />

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ジェム合成カード -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="ジェム合成"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/gem" />

                    <TextView
                        android:id="@+id/tv_pending_minutes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="@color/gold"
                        android:text="" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tv_gems_weapon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="4dp"
                    android:text="1分分の武器 / 10ジェム&#10;所持: 0" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_gem_synth"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="押す（長押しで連続）"
                    android:textSize="13sp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
