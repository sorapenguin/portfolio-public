# ============================================================
# 機密情報
# ============================================================
.env
.htpasswd

# ============================================================
# Python
# ============================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd

# 仮想環境
venv/
.venv/
env/

# ============================================================
# Django
# ============================================================
# SQLite（ローカル開発DB・ローカルテスト用。本番はPostgreSQL）
db.sqlite3
test_local.sqlite3

# collectstatic の出力先
staticfiles/
static_root/

# ============================================================
# 問題データ（著作権・機密のある実データを保護）
# ============================================================
config/question_data/*.json
config/question_data/*.csv
config/question_data/*.tsv
# .gitkeep は追跡対象のまま
!config/question_data/.gitkeep

# ============================================================
# Terraform
# ============================================================
*.tfstate
*.tfstate.*
.terraform/
*.tfvars
!*.tfvars.example
.terraform.lock.hcl

# ============================================================
# ログ・一時ファイル
# ============================================================
*.log
logs/

# ============================================================
# SSL/TLS 証明書
# ============================================================
*.pem
*.key
*.crt
*.csr

# ============================================================
# OS
# ============================================================
.DS_Store
Thumbs.db

